# Luke Goulden Coaching — landing page (static) + first-party tracker.

AddType application/x-httpd-php-latest .php

# index.php (variant 01) is the homepage — it is the admin-editable version, so
# colour and copy changes made in /admin.php take effect on "/" immediately.
# index.html is the frozen pre-variant build; it stays on disk as a fallback but
# is no longer served. Swap the order back to roll the old page out in seconds.
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Pretty report links. This is the URL that gets sent to Luke, so it must
  # not look like plumbing.
  #   /report/          → the report (simplest thing to remember or type)
  #   /report/results   → same thing; kept so links already sent keep working
  # Anyone with the URL can read it — it holds only aggregate view/click
  # counts, no personal data — and robots.txt + a noindex tag keep it out of
  # search. If it ever needs locking down, delete the bare /report/ rule below.
  RewriteRule ^report/?$ report.php?k=results [L,QSA]
  RewriteRule ^report/([A-Za-z0-9_\-]+)/?$ report.php?k=$1 [L,QSA]

  # The raw event log isn't personal data, but there's no reason to serve it.
  RewriteRule ^lgc-data/ - [F,L]
</IfModule>

# Belt and braces if mod_rewrite is unavailable.
<FilesMatch "\.csv$">
  Require all denied
</FilesMatch>

# Heavy assets cache hard; the page itself never caches, so edits go live at once.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
